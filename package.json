{
  "name": "panel-admin-oauth",
  "version": "1.0.0",
  "description": "Panel de administración protegido con Google OAuth2",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:css": "npx @tailwindcss/cli -i ./public/tailwind.input.css -o ./public/tailwind.generated.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./public/tailwind.input.css -o ./public/tailwind.generated.css --watch"
    ,"generate:icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "connect-mongo": "^6.0.0",
    "cookie-session": "^2.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.9.0",
    "mongoose": "^9.7.3",
    "nodemailer": "^9.0.3",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "tailwindcss": "^4.3.2"
  }
}
